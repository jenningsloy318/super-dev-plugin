{
  "hooks": {
    "PreToolUse": [
    {
      "matcher": "Skill|Agent",
      "hooks": [
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/utils/usage-tracker.mjs"]
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/block-dangerous.mjs"]
        },
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/log-commands.mjs"]
        }
      ]
    },
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/protect-files.mjs"]
        }
      ]
    },
    {
      "matcher": "mcp__github__create_pull_request",
      "hooks": [
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/require-tests-pr.mjs"]
        }
      ]
    },
    {
      "matcher": "Agent",
      "hooks": [
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/stage-gate.mjs"]
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/auto-fix.mjs"]
        },
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/run-tests.mjs"]
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": ["node", "${CLAUDE_PLUGIN_ROOT}/scripts/hooks/auto-checkpoint.mjs"]
        }
      ]
    }
  ]
  }
}
