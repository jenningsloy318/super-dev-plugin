{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation Summary Content",
  "description": "Input data for rendering implementation-summary.md.njk. Output must never contain TODO/FIXME/TBD markers.",
  "type": "object",
  "required": ["feature_name", "date", "phase_number", "phase_name", "status", "overview", "files_changed", "decisions", "tests"],
  "properties": {
    "feature_name": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "phase_number": { "type": "integer", "minimum": 1 },
    "phase_name": { "type": "string", "minLength": 3 },
    "status": { "type": "string", "enum": ["completed", "partial", "blocked"] },
    "overview": {
      "type": "string",
      "minLength": 50,
      "description": "2-4 sentence summary of what was implemented"
    },
    "files_changed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "action", "added", "removed", "purpose"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string", "enum": ["created", "modified", "deleted"] },
          "added": { "type": "integer", "minimum": 0 },
          "removed": { "type": "integer", "minimum": 0 },
          "purpose": { "type": "string", "minLength": 10 }
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "context", "decision", "rationale"],
        "properties": {
          "title": { "type": "string" },
          "context": { "type": "string" },
          "decision": { "type": "string" },
          "rationale": { "type": "string" },
          "reference": { "type": "string" }
        }
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "spec_said", "actual", "reason"],
        "properties": {
          "title": { "type": "string" },
          "spec_said": { "type": "string" },
          "actual": { "type": "string" },
          "reason": { "type": "string" }
        }
      },
      "description": "Deviations from spec (empty array = no deviations)"
    },
    "tests": {
      "type": "object",
      "required": ["unit_pass", "unit_total", "integration_pass", "integration_total"],
      "properties": {
        "unit_pass": { "type": "integer", "minimum": 0 },
        "unit_total": { "type": "integer", "minimum": 0 },
        "integration_pass": { "type": "integer", "minimum": 0 },
        "integration_total": { "type": "integer", "minimum": 0 },
        "e2e_pass": { "type": "integer", "minimum": 0 },
        "e2e_total": { "type": "integer", "minimum": 0 }
      }
    },
    "next_steps": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Next action items (empty array = phase complete)"
    }
  }
}
