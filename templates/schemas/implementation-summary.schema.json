{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation Summary Input",
  "description": "Structured input for implementation-summary.md.j2. Must not produce TODO/FIXME/TBD markers (gate-docs-drift counts them).",
  "type": "object",
  "required": ["feature_name", "date", "phase_number", "status", "overview", "files_changed", "key_decisions", "deviations", "test_results", "next_steps"],
  "properties": {
    "feature_name": { "type": "string" },
    "date": { "type": "string" },
    "phase_number": { "type": "integer", "minimum": 1 },
    "phase_name": { "type": "string" },
    "status": { "type": "string", "enum": ["Complete", "In Progress", "Blocked"] },
    "overview": { "type": "string", "minLength": 20 },
    "files_changed": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["path", "action", "added", "removed", "purpose"],
        "properties": {
          "path": {"type": "string"},
          "action": {"type": "string", "enum": ["Created", "Modified", "Deleted"]},
          "added": {"type": "integer", "minimum": 0},
          "removed": {"type": "integer", "minimum": 0},
          "purpose": {"type": "string"}
        }
      }
    },
    "key_decisions": {
      "type": "array",
      "items": {
        "type": "object", "required": ["title", "context", "decision", "rationale"],
        "properties": { "title": {"type": "string"}, "context": {"type": "string"}, "decision": {"type": "string"}, "rationale": {"type": "string"}, "file_ref": {"type": "string"} }
      }
    },
    "deviations": {
      "type": "array",
      "items": {
        "type": "object", "required": ["title", "spec_said", "actual", "reason"],
        "properties": { "title": {"type": "string"}, "spec_said": {"type": "string"}, "actual": {"type": "string"}, "reason": {"type": "string"} }
      },
      "default": []
    },
    "test_results": {
      "type": "object", "required": ["unit_pass", "unit_total", "integration_pass", "integration_total"],
      "properties": {
        "unit_pass": {"type": "integer", "minimum": 0},
        "unit_total": {"type": "integer", "minimum": 0},
        "integration_pass": {"type": "integer", "minimum": 0},
        "integration_total": {"type": "integer", "minimum": 0},
        "e2e_pass": {"type": "integer", "minimum": 0, "default": 0},
        "e2e_total": {"type": "integer", "minimum": 0, "default": 0}
      }
    },
    "next_steps": { "type": "array", "items": {"type": "string"}, "default": [] }
  }
}
