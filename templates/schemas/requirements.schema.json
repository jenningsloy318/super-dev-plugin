{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirements Input",
  "description": "Structured input for requirements.md.j2 template. Produces gate-requirements.sh compliant markdown.",
  "type": "object",
  "required": ["title", "date", "type", "priority", "status", "executive_summary", "surface_request", "five_whys", "jtbd", "stakeholders", "workflow", "solution_options", "acceptance_criteria", "non_functional_requirements", "recommendations", "assumptions"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "date": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["Feature", "Bug Fix", "Improvement"]
    },
    "priority": {
      "type": "string",
      "enum": ["High", "Medium", "Low"]
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Review", "Approved"]
    },
    "executive_summary": {
      "type": "string",
      "minLength": 50,
      "description": "2-3 sentence overview of the real need"
    },
    "surface_request": {
      "type": "string",
      "minLength": 20,
      "description": "What the user explicitly asked for"
    },
    "five_whys": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "type": "string" }
    },
    "jtbd": {
      "type": "object",
      "required": ["situation", "motivation", "outcome", "functional", "emotional", "social"],
      "properties": {
        "situation": { "type": "string" },
        "motivation": { "type": "string" },
        "outcome": { "type": "string" },
        "functional": { "type": "string" },
        "emotional": { "type": "string" },
        "social": { "type": "string" }
      }
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "description"],
        "properties": {
          "role": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["before", "after"],
      "properties": {
        "before": { "type": "string" },
        "after": { "type": "string" }
      }
    },
    "solution_options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "pros", "cons", "effort"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "pros": { "type": "string" },
          "cons": { "type": "string" },
          "effort": { "type": "string" }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-\\d{2}$",
            "description": "Sequential ID: AC-01, AC-02, etc."
          },
          "description": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "non_functional_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "priority", "description"],
        "properties": {
          "category": {
            "type": "string",
            "description": "Must include at least one of: Performance, Security, Accessibility"
          },
          "priority": {
            "type": "string",
            "enum": ["Must", "Should", "Could"]
          },
          "description": { "type": "string" }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
