{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirements Content",
  "description": "Input data for rendering requirements.md.njk into gate-compliant markdown.",
  "type": "object",
  "required": ["title", "date", "type", "priority", "executive_summary", "surface_request", "five_whys", "jtbd", "stakeholders", "workflow_before", "workflow_after", "acceptance_criteria", "non_functional_requirements", "recommendations"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "description": "Feature/Fix title for the heading"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date (YYYY-MM-DD)"
    },
    "type": {
      "type": "string",
      "enum": ["feature", "bug-fix", "refactor", "enhancement"],
      "description": "Requirement type"
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"],
      "description": "Priority level"
    },
    "status": {
      "type": "string",
      "description": "Document status (defaults to 'draft')"
    },
    "executive_summary": {
      "type": "string",
      "minLength": 50,
      "description": "2-3 sentence summary"
    },
    "surface_request": {
      "type": "string",
      "minLength": 20,
      "description": "What the user literally asked for"
    },
    "five_whys": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "type": "string", "minLength": 10 },
      "description": "5 Whys analysis statements"
    },
    "jtbd": {
      "type": "object",
      "required": ["situation", "motivation", "outcome", "functional", "emotional", "social"],
      "properties": {
        "situation": { "type": "string", "minLength": 10 },
        "motivation": { "type": "string", "minLength": 10 },
        "outcome": { "type": "string", "minLength": 10 },
        "functional": { "type": "string", "minLength": 5 },
        "emotional": { "type": "string", "minLength": 5 },
        "social": { "type": "string", "minLength": 5 }
      },
      "description": "Job to Be Done framework"
    },
    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "impact"],
        "properties": {
          "role": { "type": "string" },
          "impact": { "type": "string" }
        }
      },
      "description": "Stakeholder roles and impacts"
    },
    "workflow_before": {
      "type": "string",
      "minLength": 20,
      "description": "Current state / pain points"
    },
    "workflow_after": {
      "type": "string",
      "minLength": 20,
      "description": "Desired state after implementation"
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description", "pros", "cons", "effort"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "pros": { "type": "array", "items": { "type": "string" } },
          "cons": { "type": "array", "items": { "type": "string" } },
          "effort": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      },
      "description": "Solution options (optional)"
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-\\d{2}$",
            "description": "AC-01, AC-02, etc."
          },
          "description": {
            "type": "string",
            "minLength": 10,
            "description": "Specific, testable, measurable criterion"
          }
        }
      },
      "description": "Acceptance criteria (min 2 for gate)"
    },
    "non_functional_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["category", "priority", "description"],
        "properties": {
          "category": {
            "type": "string",
            "description": "e.g., Performance, Security, Accessibility"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "description": { "type": "string", "minLength": 10 }
        }
      },
      "description": "Non-functional requirements (gate needs NFR keywords)"
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Questions needing resolution (optional)"
    },
    "recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "description": "Recommendations"
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Assumptions that could invalidate requirements (optional)"
    }
  }
}
