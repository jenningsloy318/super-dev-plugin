{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation Plan Input",
  "description": "Structured input for implementation-plan.md.j2. Produces Phase N headings that gate-implementation-complete.sh can count.",
  "type": "object",
  "required": ["feature_name", "date", "spec_filename", "total_effort", "phases", "cross_cutting", "milestones"],
  "properties": {
    "feature_name": { "type": "string" },
    "date": { "type": "string" },
    "spec_filename": { "type": "string" },
    "total_effort": { "type": "string" },
    "phases": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["number", "name", "domain", "effort", "objective", "scope", "tasks", "acceptance_criteria", "risks"],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "name": { "type": "string" },
          "domain": { "type": "string", "enum": ["rust", "go", "frontend", "backend", "mixed"] },
          "effort": { "type": "string" },
          "objective": { "type": "string" },
          "depends_on": { "type": "array", "items": {"type": "string"}, "default": [] },
          "parallelizable_with": { "type": "array", "items": {"type": "string"}, "default": [] },
          "scope": { "type": "string" },
          "tasks": {
            "type": "array", "minItems": 1,
            "items": { "type": "object", "required": ["description", "files", "type"], "properties": { "description": {"type": "string"}, "files": {"type": "array", "items": {"type": "string"}}, "type": {"type": "string"} } }
          },
          "acceptance_criteria": { "type": "array", "items": {"type": "string"} },
          "risks": { "type": "array", "items": {"type": "string"} }
        }
      }
    },
    "cross_cutting": {
      "type": "array",
      "items": { "type": "object", "required": ["title", "description"], "properties": { "title": {"type": "string"}, "description": {"type": "string"} } }
    },
    "milestones": {
      "type": "array",
      "items": { "type": "object", "required": ["name", "phase", "deliverable", "verification"], "properties": { "name": {"type": "string"}, "phase": {"type": "integer"}, "deliverable": {"type": "string"}, "verification": {"type": "string"} } }
    }
  }
}
