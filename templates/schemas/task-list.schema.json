{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task List Input",
  "description": "Structured input for task-list.md.j2 template. Produces gate-task-list.sh compliant markdown.",
  "type": "object",
  "required": ["feature_name", "date", "spec_filename", "plan_filename", "total_task_count", "total_effort", "phases"],
  "properties": {
    "feature_name": { "type": "string" },
    "date": { "type": "string" },
    "spec_filename": { "type": "string" },
    "plan_filename": { "type": "string" },
    "total_task_count": { "type": "integer", "minimum": 1 },
    "total_effort": { "type": "string" },
    "phases": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["number", "name", "milestone", "effort", "tasks"],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "name": { "type": "string" },
          "milestone": { "type": "string" },
          "effort": { "type": "string" },
          "tasks": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "description", "files", "type", "effort"],
              "properties": {
                "id": { "type": "string", "pattern": "^T-\\d{3}$" },
                "description": { "type": "string" },
                "files": { "type": "array", "items": {"type": "string"} },
                "type": { "type": "string", "enum": ["implementation", "test", "config", "documentation"] },
                "effort": { "type": "string" },
                "depends_on": { "type": "array", "items": {"type": "string"}, "default": [] }
              }
            }
          }
        }
      }
    }
  }
}
