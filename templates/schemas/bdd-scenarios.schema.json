{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BDD Scenarios Input",
  "description": "Structured input for bdd-scenarios.md.j2 template. Produces gate-bdd.sh compliant markdown.",
  "type": "object",
  "required": ["feature_name", "date", "source_filename", "total_scenario_count", "features", "traceability"],
  "properties": {
    "feature_name": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the feature being specified"
    },
    "date": {
      "type": "string",
      "description": "ISO date or datetime string"
    },
    "source_filename": {
      "type": "string",
      "pattern": "^\\d{2}-requirements\\.md$",
      "description": "Filename of the source requirements document (e.g., 01-requirements.md)"
    },
    "total_scenario_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of scenarios across all features"
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "description": "Feature groups containing scenarios",
      "items": {
        "type": "object",
        "required": ["name", "scenarios"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Feature area name"
          },
          "scenarios": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["index", "title", "ac_ref", "priority", "given", "when", "then"],
              "properties": {
                "index": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Global sequential index (1-based). Renders as SCENARIO-001, SCENARIO-002, etc."
                },
                "title": {
                  "type": "string",
                  "minLength": 5,
                  "description": "Meaningful behavior title in business language"
                },
                "ac_ref": {
                  "type": "string",
                  "pattern": "^AC-\\d{2}",
                  "description": "Reference to acceptance criterion (e.g., AC-01, AC-02)"
                },
                "priority": {
                  "type": "string",
                  "enum": ["P0", "P1", "P2"],
                  "description": "Scenario priority level"
                },
                "given": {
                  "type": "string",
                  "minLength": 10,
                  "description": "Precondition in business language (no technical jargon)"
                },
                "when": {
                  "type": "string",
                  "minLength": 10,
                  "description": "Single trigger action in business language"
                },
                "then": {
                  "type": "string",
                  "minLength": 10,
                  "description": "Verifiable outcome in business language"
                },
                "and_clauses": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 5
                  },
                  "default": [],
                  "description": "Additional And clauses for the scenario"
                }
              }
            }
          }
        }
      }
    },
    "traceability": {
      "type": "array",
      "minItems": 1,
      "description": "AC-to-scenario mapping for traceability matrix",
      "items": {
        "type": "object",
        "required": ["ac_id", "description", "scenarios"],
        "properties": {
          "ac_id": {
            "type": "string",
            "pattern": "^AC-\\d{2}$",
            "description": "Acceptance criterion ID (e.g., AC-01)"
          },
          "description": {
            "type": "string",
            "description": "Brief description of the acceptance criterion"
          },
          "scenarios": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^SCENARIO-\\d{3}$"
            },
            "description": "List of scenario IDs covering this AC"
          }
        }
      }
    }
  }
}
