{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spec Review Content",
  "description": "Input data for rendering spec-review.md.njk. Output always contains all 8 dimension names and grounding verification keywords.",
  "type": "object",
  "required": ["feature_name", "date", "verdict", "specification_file", "rationale", "severity_counts", "findings", "dimensions", "coverage_matrix"],
  "properties": {
    "feature_name": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "verdict": {
      "type": "string",
      "enum": ["APPROVED", "REVISIONS NEEDED", "REJECTED"]
    },
    "specification_file": {
      "type": "string",
      "description": "Filename of the spec being reviewed (e.g., '01-specification.md')"
    },
    "rationale": { "type": "string", "minLength": 10 },
    "severity_counts": {
      "type": "object",
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "issue", "recommendation"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
          "issue": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "dimensions": {
      "type": "object",
      "required": ["completeness", "consistency", "feasibility", "testability", "traceability", "grounding", "complexity", "ambiguity"],
      "properties": {
        "completeness": { "$ref": "#/$defs/dimension" },
        "consistency": { "$ref": "#/$defs/dimension" },
        "feasibility": { "$ref": "#/$defs/dimension" },
        "testability": { "$ref": "#/$defs/dimension" },
        "traceability": { "$ref": "#/$defs/dimension" },
        "grounding": { "$ref": "#/$defs/grounding_dimension" },
        "complexity": { "$ref": "#/$defs/dimension" },
        "ambiguity": { "$ref": "#/$defs/dimension" }
      }
    },
    "dimensions_at_zero": { "type": "integer", "minimum": 0 },
    "coverage_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "spec_section", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^AC-\\d{2}$" },
          "spec_section": { "type": "string" },
          "status": { "type": "string", "enum": ["Covered", "Missing", "Partial"] }
        }
      }
    }
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "required": ["status", "assessment"],
      "properties": {
        "status": { "type": "string", "enum": ["Pass", "Fail", "Partial"] },
        "assessment": { "type": "string", "minLength": 20 },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "severity", "issue", "recommendation"],
            "properties": {
              "id": { "type": "string" },
              "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
              "issue": { "type": "string" },
              "recommendation": { "type": "string" }
            }
          }
        }
      }
    },
    "grounding_dimension": {
      "type": "object",
      "required": ["status", "assessment", "verifications"],
      "properties": {
        "status": { "type": "string", "enum": ["Pass", "Fail", "Partial"] },
        "assessment": { "type": "string", "minLength": 20 },
        "verifications": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["reference", "result"],
            "properties": {
              "reference": { "type": "string", "description": "file/function path" },
              "result": {
                "type": "string",
                "enum": ["confirmed", "not found", "hallucinated"],
                "description": "Gate requires these keywords"
              }
            }
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "severity", "issue", "recommendation"],
            "properties": {
              "id": { "type": "string" },
              "severity": { "type": "string" },
              "issue": { "type": "string" },
              "recommendation": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
