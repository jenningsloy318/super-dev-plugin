{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Technical Specification Input",
  "description": "Structured input for specification.md.j2 template. Produces gate-spec-trace.sh compliant markdown (SCENARIO-NNN refs + testing strategy text).",
  "type": "object",
  "required": ["feature_name", "date", "requirements_filename", "bdd_filename", "overview", "architecture_sections", "data_models", "api_endpoints", "implementation_sections", "testing_overview", "unit_tests", "integration_tests", "e2e_tests", "scenario_refs", "non_functional", "risks"],
  "properties": {
    "feature_name": { "type": "string" },
    "date": { "type": "string" },
    "requirements_filename": { "type": "string" },
    "bdd_filename": { "type": "string" },
    "architecture_filename": { "type": "string" },
    "overview": { "type": "string", "minLength": 50 },
    "architecture_sections": {
      "type": "array", "minItems": 1,
      "items": { "type": "object", "required": ["title", "content"], "properties": { "title": {"type": "string"}, "content": {"type": "string"} } }
    },
    "data_models": {
      "type": "array",
      "items": { "type": "object", "required": ["name", "description", "schema"], "properties": { "name": {"type": "string"}, "description": {"type": "string"}, "schema": {"type": "string"}, "language": {"type": "string"} } }
    },
    "api_endpoints": {
      "type": "array",
      "items": {
        "type": "object", "required": ["method", "path", "description", "response", "errors"],
        "properties": {
          "method": {"type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]},
          "path": {"type": "string"},
          "description": {"type": "string"},
          "request_body": {"type": "string"},
          "response": {"type": "string"},
          "errors": { "type": "array", "items": { "type": "object", "required": ["code", "description"], "properties": { "code": {"type": "string"}, "description": {"type": "string"} } } }
        }
      }
    },
    "implementation_sections": {
      "type": "array",
      "items": { "type": "object", "required": ["title", "content"], "properties": { "title": {"type": "string"}, "content": {"type": "string"} } }
    },
    "testing_overview": { "type": "string", "minLength": 20 },
    "unit_tests": { "type": "array", "minItems": 1, "items": {"type": "string"} },
    "integration_tests": { "type": "array", "items": {"type": "string"} },
    "e2e_tests": { "type": "array", "items": {"type": "string"} },
    "scenario_refs": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["scenario_id", "test_type", "coverage"],
        "properties": {
          "scenario_id": {"type": "string", "pattern": "^SCENARIO-\\d{3}$"},
          "test_type": {"type": "string"},
          "coverage": {"type": "string", "enum": ["Full", "Partial", "Planned"]}
        }
      }
    },
    "non_functional": {
      "type": "array",
      "items": { "type": "object", "required": ["category", "details"], "properties": { "category": {"type": "string"}, "details": {"type": "string"} } }
    },
    "risks": {
      "type": "array",
      "items": { "type": "object", "required": ["description", "likelihood", "impact", "mitigation"], "properties": { "description": {"type": "string"}, "likelihood": {"type": "string"}, "impact": {"type": "string"}, "mitigation": {"type": "string"} } }
    }
  }
}
