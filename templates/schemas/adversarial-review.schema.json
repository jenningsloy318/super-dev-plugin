{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adversarial Review Input",
  "description": "Structured input for adversarial-review.md.j2. Gate checks first line with PASS|REJECT|HALT. For PASS verdict: the word REJECT/HALT must NOT appear anywhere in the document.",
  "type": "object",
  "required": ["feature_name", "date", "verdict", "verdict_rationale", "destructive_actions", "skeptic", "architect", "minimalist", "all_findings", "conclusion"],
  "properties": {
    "feature_name": { "type": "string" },
    "date": { "type": "string" },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "REJECT"],
      "description": "Must be exactly PASS or REJECT. Gate takes first line matching these words."
    },
    "verdict_rationale": {
      "type": "string",
      "description": "CRITICAL: If verdict is PASS, this text must NOT contain the words REJECT or HALT anywhere."
    },
    "destructive_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "pattern", "safeguard", "status"],
        "properties": {
          "category": { "type": "string", "enum": ["DAT", "IRR", "PRD", "PRM", "SEC"] },
          "pattern": { "type": "string" },
          "safeguard": { "type": "string" },
          "status": { "type": "string", "enum": ["Clear", "Guarded", "Unguarded"] }
        }
      },
      "default": []
    },
    "skeptic": { "$ref": "#/$defs/lens_review" },
    "architect": { "$ref": "#/$defs/lens_review" },
    "minimalist": { "$ref": "#/$defs/lens_review" },
    "all_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "lens", "severity", "vector", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^AF-\\d{3}$" },
          "lens": { "type": "string", "enum": ["Skeptic", "Architect", "Minimalist"] },
          "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low"] },
          "vector": { "type": "string" },
          "status": { "type": "string", "enum": ["Open", "Resolved", "Accepted"] }
        }
      },
      "default": []
    },
    "conclusion": {
      "type": "string",
      "description": "CRITICAL: If verdict is PASS, this text must NOT contain the words REJECT or HALT."
    }
  },
  "$defs": {
    "lens_review": {
      "type": "object",
      "required": ["assessment", "findings"],
      "properties": {
        "assessment": {
          "type": "string",
          "description": "CRITICAL: If verdict is PASS, must NOT contain words REJECT or HALT."
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "severity", "description", "vector", "mitigation"],
            "properties": {
              "id": { "type": "string" },
              "severity": { "type": "string" },
              "description": { "type": "string" },
              "vector": { "type": "string" },
              "mitigation": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
