{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code Review Input",
  "description": "Structured input for code-review.md.j2 template. Produces gate-review.sh compliant markdown. NEVER produces **Critical** bold text.",
  "type": "object",
  "required": ["feature_name", "date", "verdict", "verdict_rationale", "files_reviewed", "critical_count", "high_count", "medium_count", "low_count", "findings", "scenario_coverage", "files_changed", "additional_checklist"],
  "properties": {
    "feature_name": { "type": "string" },
    "date": { "type": "string" },
    "verdict": {
      "type": "string",
      "enum": ["Approved", "Approved with Comments", "Changes Requested", "Blocked"],
      "description": "Gate checks for 'approved' (case-insensitive) without 'changes requested' or 'blocked'"
    },
    "verdict_rationale": { "type": "string" },
    "files_reviewed": { "type": "integer", "minimum": 1 },
    "critical_count": { "type": "integer", "minimum": 0 },
    "high_count": { "type": "integer", "minimum": 0 },
    "medium_count": { "type": "integer", "minimum": 0 },
    "low_count": { "type": "integer", "minimum": 0 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "file", "line", "category", "description", "recommendation"],
        "properties": {
          "id": { "type": "string", "pattern": "^F-\\d{3}$" },
          "title": { "type": "string" },
          "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low", "Info"] },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "category": { "type": "string" },
          "description": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "scenario_coverage": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario_id", "status"],
        "properties": {
          "scenario_id": { "type": "string", "pattern": "^SCENARIO-\\d{3}$" },
          "status": { "type": "string", "enum": ["Covered", "Missing", "Partial"] }
        }
      }
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action", "added", "removed"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string", "enum": ["Created", "Modified", "Deleted"] },
          "added": { "type": "integer", "minimum": 0 },
          "removed": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "additional_checklist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "passed"],
        "properties": {
          "description": { "type": "string" },
          "passed": { "type": "boolean" }
        }
      },
      "default": []
    }
  }
}
