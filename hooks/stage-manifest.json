{
  "version": "2.0.0",
  "description": "Maps super-dev agent types to required prerequisite artifacts from previous stages. Uses glob patterns (*-doctype.md) for dynamic incremental naming.",
  "gates": {
    "super-dev:bdd-scenario-writer": {
      "stage": "3.5",
      "description": "BDD Scenario Writing (Stage 3.5) requires completed requirements",
      "requires": ["[doc-index]-requirements.md"],
      "sections": {
        "[doc-index]-requirements.md": ["Acceptance Criteria"]
      }
    },
    "super-dev:research-agent": {
      "stage": "4",
      "description": "Research (Stage 4) requires completed requirements and BDD scenarios",
      "requires": ["[doc-index]-requirements.md", "[doc-index]-behavior-scenarios.md"],
      "sections": {
        "[doc-index]-behavior-scenarios.md": ["Scenario", "Given"]
      }
    },
    "super-dev:debug-analyzer": {
      "stage": "5",
      "description": "Debug analysis (Stage 5) requires completed requirements",
      "requires": ["[doc-index]-requirements.md"],
      "sections": {}
    },
    "super-dev:code-assessor": {
      "stage": "6",
      "description": "Code assessment (Stage 6) requires research report",
      "requires": ["[doc-index]-research-report.md"],
      "sections": {}
    },
    "super-dev:architecture-agent": {
      "stage": "6.3",
      "description": "Architecture design (Stage 6.3) requires assessment",
      "requires": ["[doc-index]-code-assessment.md"],
      "sections": {}
    },
    "super-dev:product-designer": {
      "stage": "6.4",
      "description": "Product design (Stage 6.4) requires assessment with both arch and UI",
      "requires": ["[doc-index]-code-assessment.md"],
      "sections": {}
    },
    "super-dev:ui-ux-designer": {
      "stage": "6.5",
      "description": "UI/UX design (Stage 6.5) requires assessment",
      "requires": ["[doc-index]-code-assessment.md"],
      "sections": {}
    },
    "super-dev:spec-writer": {
      "stage": "7",
      "description": "Spec writing (Stage 7) requires assessment and design documents",
      "requires": ["[doc-index]-code-assessment.md"],
      "sections": {}
    },
    "super-dev:spec-reviewer": {
      "stage": "8",
      "description": "Spec review (Stage 8) requires specification, implementation plan, and task list",
      "requires": ["[doc-index]-specification.md", "[doc-index]-implementation-plan.md", "[doc-index]-task-list.md"],
      "sections": {
        "[doc-index]-specification.md": ["Testing Strategy"]
      }
    },
    "super-dev:dev-executor": {
      "stage": "9",
      "description": "Execution (Stage 9) requires complete specification, plan, and task list",
      "requires": ["[doc-index]-specification.md", "[doc-index]-implementation-plan.md", "[doc-index]-task-list.md"],
      "sections": {
        "[doc-index]-specification.md": ["Implementation"],
        "[doc-index]-task-list.md": ["Task"]
      }
    },
    "super-dev:qa-agent": {
      "stage": "9",
      "description": "QA (Stage 9) requires complete specification and BDD scenarios",
      "requires": ["[doc-index]-specification.md", "[doc-index]-behavior-scenarios.md"],
      "sections": {}
    },
    "super-dev:code-reviewer": {
      "stage": "10",
      "description": "Code review (Stage 10) requires specification (after execution)",
      "requires": ["[doc-index]-specification.md"],
      "sections": {}
    },
    "super-dev:adversarial-reviewer": {
      "stage": "10",
      "description": "Adversarial review (Stage 10) requires specification (after execution)",
      "requires": ["[doc-index]-specification.md"],
      "sections": {}
    },
    "super-dev:docs-executor": {
      "stage": "11",
      "description": "Documentation (Stage 11) requires specification, all implementation phases complete, and gate-implementation-complete.sh PASS",
      "requires": ["[doc-index]-specification.md", "[doc-index]-workflow-tracking.json"],
      "sections": {},
      "gate": "gate-implementation-complete.sh"
    },
    "super-dev:handoff-writer": {
      "stage": "11.5",
      "description": "Handoff (Stage 11.5) requires specification directory with all artifacts",
      "requires": ["[doc-index]-specification.md"],
      "sections": {}
    }
  }
}
