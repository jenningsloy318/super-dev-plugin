{
  "version": "4.0.0",
  "description": "Maps super-dev agent types to required prerequisite artifacts and stage status checks. Uses glob patterns (*-doctype.md) for dynamic incremental naming. previousStages lists stage IDs that must be 'complete' or 'skipped' in workflow-tracking.json before this agent can spawn. Agents matching a _group pattern inherit the group's gate definition.",
  "groups": {
    "stage9-implementer": {
      "match": ["super-dev:dev-executor", "super-dev:rust-developer", "super-dev:golang-developer", "super-dev:frontend-developer", "super-dev:backend-developer", "super-dev:ios-developer", "super-dev:android-developer", "super-dev:windows-app-developer", "super-dev:macos-app-developer"],
      "gate": {
        "stage": "9",
        "description": "Implementation (Stage 9.2) requires complete specification, plan, task list, and approved spec review",
        "previousStages": [8],
        "requires": ["[doc-index]-specification.md", "[doc-index]-implementation-plan.md", "[doc-index]-task-list.md", "[doc-index]-spec-review.md"],
        "sections": {
          "[doc-index]-specification.md": ["Implementation"],
          "[doc-index]-task-list.md": ["Task"]
        }
      }
    },
    "stage10-reviewer": {
      "match": ["super-dev:code-reviewer", "super-dev:adversarial-reviewer"],
      "gate": {
        "stage": "10",
        "description": "Review (Stage 10) requires specification, implementation summary, requirements, and BDD scenarios. No previousStages check — participates in implementation iteration loop.",
        "requires": ["[doc-index]-specification.md", "[doc-index]-implementation-summary.md", "[doc-index]-requirements.md", "[doc-index]-bdd-scenarios.md"],
        "sections": {}
      }
    },
    "stage6-designer": {
      "match": ["super-dev:architecture-designer", "super-dev:architecture-improver", "super-dev:product-designer", "super-dev:ui-ux-designer"],
      "gate": {
        "stage": "6",
        "description": "Design (Stage 6.x) requires code assessment",
        "previousStages": [6],
        "requires": ["[doc-index]-code-assessment.md"],
        "sections": {}
      }
    }
  },
  "gates": {
    "super-dev:bdd-scenario-writer": {
      "stage": "3.5",
      "description": "BDD Scenario Writing (Stage 3.5) requires completed requirements",
      "previousStages": [3],
      "requires": ["[doc-index]-requirements.md"],
      "sections": {
        "[doc-index]-requirements.md": ["Acceptance Criteria"]
      }
    },
    "super-dev:research-agent": {
      "stage": "4",
      "description": "Research (Stage 4) requires completed requirements and BDD scenarios",
      "previousStages": [3.5],
      "requires": ["[doc-index]-requirements.md", "[doc-index]-bdd-scenarios.md"],
      "sections": {
        "[doc-index]-bdd-scenarios.md": ["Scenario", "Given"]
      }
    },
    "super-dev:debug-analyzer": {
      "stage": "5",
      "description": "Debug analysis (Stage 5) requires completed research",
      "previousStages": [4],
      "requires": ["[doc-index]-requirements.md"],
      "sections": {}
    },
    "super-dev:code-assessor": {
      "stage": "6",
      "description": "Code assessment (Stage 6) requires research report",
      "previousStages": [4],
      "requires": ["[doc-index]-research-report.md"],
      "sections": {}
    },
    "super-dev:spec-writer": {
      "stage": "7",
      "description": "Spec writing (Stage 7) requires requirements, BDD scenarios, and code assessment",
      "previousStages": [6],
      "requires": ["[doc-index]-requirements.md", "[doc-index]-bdd-scenarios.md", "[doc-index]-code-assessment.md"],
      "sections": {}
    },
    "super-dev:spec-reviewer": {
      "stage": "8",
      "description": "Spec review (Stage 8) requires specification, implementation plan, task list, requirements, and BDD scenarios",
      "requires": ["[doc-index]-specification.md", "[doc-index]-implementation-plan.md", "[doc-index]-task-list.md", "[doc-index]-requirements.md", "[doc-index]-bdd-scenarios.md"],
      "sections": {
        "[doc-index]-specification.md": ["Testing Strategy"]
      }
    },
    "super-dev:tdd-guide": {
      "stage": "9",
      "description": "TDD (Stage 9.1) requires specification, requirements, BDD scenarios, implementation plan, task list, and approved spec review",
      "previousStages": [8],
      "requires": ["[doc-index]-specification.md", "[doc-index]-requirements.md", "[doc-index]-bdd-scenarios.md", "[doc-index]-implementation-plan.md", "[doc-index]-task-list.md", "[doc-index]-spec-review.md"],
      "sections": {
        "[doc-index]-specification.md": ["Implementation"],
        "[doc-index]-task-list.md": ["Task"]
      }
    },
    "super-dev:qa-agent": {
      "stage": "9",
      "description": "QA verification (Stage 9.3) requires specification, BDD scenarios, implementation plan, task list, and approved spec review",
      "previousStages": [8],
      "requires": ["[doc-index]-specification.md", "[doc-index]-bdd-scenarios.md", "[doc-index]-implementation-plan.md", "[doc-index]-task-list.md", "[doc-index]-spec-review.md"],
      "sections": {}
    },
    "super-dev:docs-executor": {
      "stage": "11",
      "description": "Documentation (Stage 11) requires specification, all implementation phases complete, and gate-implementation-complete.sh PASS",
      "previousStages": [10],
      "requires": ["[doc-index]-specification.md", "[doc-index]-workflow-tracking.json"],
      "sections": {},
      "gate": "gate-implementation-complete.sh"
    },
    "super-dev:handoff-writer": {
      "stage": "11.5",
      "description": "Handoff (Stage 11.5) requires specification directory with all artifacts",
      "previousStages": [11],
      "requires": ["[doc-index]-specification.md"],
      "sections": {}
    }
  }
}
