{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "super-dev/schemas/code-review-output.json",
  "title": "CodeReviewOutput",
  "description": "Structured return from code-reviewer (Stage 10).",
  "type": "object",
  "required": ["doc_path", "verdict", "findings"],
  "additionalProperties": false,
  "properties": {
    "doc_path": { "type": "string" },
    "verdict": {
      "type": "string",
      "enum": ["Approved", "Approved with Comments", "Changes Requested", "Blocked"],
      "description": "Only 'Approved' (no findings of any severity) is a hard-PASS. Any other value re-enters the iteration loop."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "severity", "issue"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "category": {
            "type": "string",
            "description": "e.g. correctness, security, performance, maintainability, style"
          },
          "issue": { "type": "string" },
          "recommendation": { "type": "string" },
          "uncertain": { "type": "boolean", "description": "True when reviewer confidence < 0.5; finding still reported." }
        }
      }
    },
    "dimensions_covered": {
      "type": "array",
      "items": { "type": "string" },
      "description": "All review dimensions inspected (correctness, security, perf, …) regardless of whether findings were produced."
    },
    "summary": { "type": "string" }
  }
}
