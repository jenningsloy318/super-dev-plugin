{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "super-dev/schemas/impl-summary-output.json",
  "title": "ImplSummaryOutput",
  "description": "Structured return from impl-summary-writer agent (Step 9.3).",
  "type": "object",
  "required": ["doc_path", "phase_number", "files_changed"],
  "additionalProperties": false,
  "properties": {
    "doc_path": {
      "type": "string",
      "description": "Absolute path to the implementation-summary.md (appended-to per phase)."
    },
    "phase_number": { "type": "integer", "minimum": 1 },
    "phase_name": { "type": "string" },
    "files_changed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created":  { "type": "array", "items": { "type": "string" } },
        "modified": { "type": "array", "items": { "type": "string" } },
        "deleted":  { "type": "array", "items": { "type": "string" } }
      }
    },
    "tasks_complete": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Task identifiers from the plan that this phase completed."
    },
    "tasks_partial": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Task identifiers from the plan that remain partial after this phase."
    },
    "summary": { "type": "string" }
  }
}
